# Local-first defaults. Keep user secrets on the user's machine.
APPLYPILOT_PROVIDER=rules

# Optional BYOK providers for later phases.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_MODEL=

# SaaS security.
APPLYPILOT_ADMIN_TOKEN=
APPLYPILOT_FULFILLMENT_SECRET=
APPLYPILOT_ALLOWED_ORIGINS=https://app.example.com
APPLYPILOT_CHECKOUT_SUCCESS_URL=https://app.example.com/checkout.html?paid=1&session_id={CHECKOUT_SESSION_ID}
APPLYPILOT_CHECKOUT_CANCEL_URL=https://app.example.com/checkout.html?cancelled=1

# Stripe subscriptions.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
APPLYPILOT_STRIPE_PRICE_PRO_BYOK=
APPLYPILOT_STRIPE_PRICE_PRO_MANAGED=
APPLYPILOT_STRIPE_PRICE_TEAM=

# Razorpay subscriptions.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_TOTAL_COUNT=120
APPLYPILOT_RAZORPAY_PLAN_PRO_BYOK=
APPLYPILOT_RAZORPAY_PLAN_PRO_MANAGED=
APPLYPILOT_RAZORPAY_PLAN_TEAM=
